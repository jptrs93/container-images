# PostgreSQL initialization variables. These affect only a new, empty PGDATA.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=app

# Enable S3-compatible pgBackRest backups.
PGBACKREST_ENABLED=true
PGBACKREST_STANZA=app-prod
PGBACKREST_S3_ENDPOINT=https://s3.example.internal
PGBACKREST_S3_BUCKET=postgres-backups
PGBACKREST_S3_REGION=us-east-1
PGBACKREST_S3_KEY=replace-with-access-key
PGBACKREST_S3_KEY_SECRET=replace-with-secret-key

# Set false only for a trusted endpoint with a self-signed certificate.
PGBACKREST_S3_VERIFY_TLS=true

# Full backups run Sunday; differential backups run Monday through Saturday.
PGBACKREST_FULL_SCHEDULE=0 2 * * 0
PGBACKREST_DIFF_SCHEDULE=0 2 * * 1-6
