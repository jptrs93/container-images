# Bootstrap superuser and database. config.yaml reconciles the declared superuser password on every start.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=app

# Secret values referenced by the Compose example's config mount. Prefer an orchestrator secret integration in production.
APP_DATABASE_PASSWORD=replace-with-a-different-long-random-password
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key
